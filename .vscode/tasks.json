{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc build active file",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-I/usr/include/hdf5/serial",
                "BurstDetector.cpp",
                "FFTUtils.cpp",
                "HDF5Reader.cpp",
                "PSD.cpp",
                "Whiten.cpp",
                "main.cpp",
                "-o",
                "${fileDirname}/main",
                "-lhdf5_serial_cpp",
                "-lhdf5_serial",
                "-lfftw3"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}